{
  "name": "章悟式∞競輪OS 2車単PDF API",
  "version": "1.1.0-two-pdf-optional-ex",
  "status": "unvalidated",
  "bet_type": "2車単",
  "supported_field_sizes": [5, 6, 7, 8, 9],
  "inputs": [
    "netkeirin基本情報PDF",
    "netkeirin 2車単人気順オッズPDF",
    "任意EX文字データ"
  ],
  "forbidden_prediction_inputs": [
    "Web自動取得",
    "スクリーンショット",
    "結果・払戻",
    "推測による欠損補完"
  ],
  "document_detection": "入力欄ごとの専用解析器による検証",
  "probability_model": {
    "method": "two_stage_line_then_order_monte_carlo",
    "odds_used_for_probability": false,
